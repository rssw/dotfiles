#!/bin/sh

# uriencode with fallback implementions, see:
# https://stackoverflow.com/questions/296536/how-to-urlencode-data-for-curl-command

# https://stackoverflow.com/a/11111040/4935114
#!/bin/sh

# uriencode script with multiple fallbacks
# URL-encodes the first argument passed to the script

if command -v ruby > /dev/null 2>&1; then

    ruby -r cgi -e 'puts CGI.escape(ARGV[0])' "$@"
    exit
fi

if command -v python3 > /dev/null 2>&1; then
    python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$@"
    exit
fi

if command -v node > /dev/null 2>&1; then
    node -e "console.log(encodeURIComponent(process.argv[1]))" "$@"
    exit
fi

echo "Error: No suitable command found to encode. Tested: ruby, python3, node.js" >&2
exit 2

