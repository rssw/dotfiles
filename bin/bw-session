#!/bin/sh

set -eu

session_dir=${HOME:?HOME must be set}/.local/share/bitwarden
session_file=${BW_SESSION_FILE:-$session_dir/session.env}

ensure_dir() {
	[ -d "$1" ] || mkdir -p "$1"
}

status_json() {
	bw status 2>/dev/null || true
}

status_field() {
	field_name=$1
	status_json | sed -n "s/.*\"$field_name\":\"\([^\"]*\)\".*/\1/p"
}

load_session() {
	if [ -f "$session_file" ]; then
		# shellcheck disable=SC1090
		. "$session_file"
	fi
}

clear_session() {
	rm -f "$session_file"
}

save_session() {
	ensure_dir "$session_dir"
	{
		printf 'export BW_SESSION=%s\n' "$(printf %s "$1" | sed "s/'/'\\''/g; s/^/'/; s/$/'/")"
	} > "$session_file"
	chmod 600 "$session_file"
	printf 'Saved Bitwarden session to %s\n' "$session_file"
}

require_bw() {
	command -v bw >/dev/null 2>&1 || {
		printf 'bw CLI is not installed\n' >&2
		exit 1
	}
}

require_bw
load_session

bw_email_default=${BW_EMAIL:-$(status_field userEmail)}

login_raw() {
	login_email=$1
	
	# Run bw login with interactive prompts going to terminal (not captured)
	# We redirect stderr to /dev/tty so prompts display, but capture stdout (the token)
	if [ -n "$login_email" ]; then
		# Try login, prompts go to terminal
		if [ -t 0 ]; then
			# Interactive terminal available
			token=$(bw login "$login_email" --raw 2>/dev/tty)
		else
			# No terminal, use normal stderr
			token=$(bw login "$login_email" --raw 2>&2)
		fi
	else
		if [ -t 0 ]; then
			token=$(bw login --raw 2>/dev/tty)
		else
			token=$(bw login --raw 2>&2)
		fi
	fi
	
	# Check if we got a valid token
	case "$token" in
		*"already logged in"*)
			# Already logged in, logout and retry
			bw logout >/dev/null 2>&1 || true
			if [ -n "$login_email" ]; then
				token=$(bw login "$login_email" --raw 2>/dev/tty)
			else
				token=$(bw login --raw 2>/dev/tty)
			fi
			;;
		"")
			# Empty token means error
			printf 'Failed to get session token\n' >&2
			return 1
			;;
	esac
	
	printf '%s\n' "$token"
}

cmd=${1:-unlock}
shift || true

case "$cmd" in
	login)
		bw_email=${1:-$bw_email_default}
		token=$(login_raw "$bw_email")
		save_session "$token"
		printf '\nSession saved and will be auto-loaded in new shells\n'
		printf 'Note: Shell wrapper function auto-sources in current shell\n'
		;;
	unlock)
		current_status=$(status_field status)
		
		case "$current_status" in
			locked)
				# Already logged in, just need to unlock
				printf 'Unlocking Bitwarden vault (enter master password)\n' >&2
				if [ -t 0 ]; then
					token=$(bw unlock --raw 2>/dev/tty)
				else
					token=$(bw unlock --raw)
				fi
				;;
			unauthenticated)
				# Need to login first
				if [ -n "$bw_email_default" ]; then
					printf 'Logging in to Bitwarden as %s\n' "$bw_email_default" >&2
					token=$(login_raw "$bw_email_default")
				else
					printf 'Logging in to Bitwarden (you will be prompted for email and password)\n' >&2
					token=$(login_raw "")
				fi
				;;
			unlocked)
				# Already unlocked, just update the session file
				printf 'Already unlocked\n' >&2
				if [ -n "${BW_SESSION:-}" ]; then
					token="$BW_SESSION"
				else
					printf 'Warning: vault is unlocked but BW_SESSION not set. Run bw-session logout and try again.\n' >&2
					exit 1
				fi
				;;
			*)
				printf 'Unknown status: %s\n' "$current_status" >&2
				exit 1
				;;
		esac
		
		save_session "$token"
		printf '\nSession saved and will be auto-loaded in new shells\n'
		printf 'Note: Shell wrapper function auto-sources in current shell\n'
		;;
	status)
		bw status
		printf '\n'
		if [ -f "$session_file" ]; then
			printf 'session file: %s\n' "$session_file"
		else
			printf 'session file: missing\n'
		fi
		;;
	test)
		if [ -z "${BW_SESSION:-}" ]; then
			printf 'BW_SESSION is not available; run `bw-session unlock`\n' >&2
			exit 1
		fi
		if bw sync >/dev/null 2>&1; then
			printf 'Bitwarden session is usable\n'
			exit 0
		fi
		printf 'Bitwarden session is not usable; run `bw-session unlock`\n' >&2
		exit 1
		;;
	sync)
		exec bw sync
		;;
	clear)
		clear_session
		printf 'Removed %s\n' "$session_file"
		;;
	logout)
		bw logout || true
		clear_session
		printf 'Logged out and removed %s\n' "$session_file"
		;;
	*)
		printf 'usage: bw-session [login [email]|unlock|status|test|sync|clear|logout]\n' >&2
		printf 'note: for this Vaultwarden setup, `unlock` uses the working login flow to obtain a session\n' >&2
		exit 1
		;;
esac
