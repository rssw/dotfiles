# ~/.notmuch-config.example
#
# Tracked template for notmuch mail indexing.
# Copied to ~/.notmuch-config if missing.
#
# Customize paths and tags.
#
[database]
path=~/.local/share/mail

[user]
name=Your Name
primary_email=your.email@example.com
other_email=your.other.email@example.com

[new]
tags=new
ignore=.mbsync-state

[search]
exclude_tags=deleted;spam

[maildir]
synchronize_flags=true