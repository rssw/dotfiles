#!/bin/sh

set -eu

manifest_file=${SECRET_MIRROR_FILE:-${HOME:?HOME must be set}/.local/share/secret-mirror/items}
secrets_dir=${SECRET_STORE_DIR:-${HOME:?HOME must be set}/.local/share/secrets}
session_file=${BW_SESSION_FILE:-${HOME:?HOME must be set}/.local/share/bitwarden/session.env}

ensure_dir() {
	[ -d "$1" ] || mkdir -p "$1"
}

load_session() {
	if [ -f "$session_file" ]; then
		# shellcheck disable=SC1090
		. "$session_file"
	fi
}

require_bw_session() {
	command -v bw >/dev/null 2>&1 || {
		printf 'bw CLI is not installed\n' >&2
		exit 1
	}
	if [ -z "${BW_SESSION:-}" ]; then
		printf 'BW_SESSION is not available; run `bw-session unlock` first\n' >&2
		exit 1
	fi
}

sync_one() {
	secret_name=$1
	item_id=$2
	target_file=$secrets_dir/$secret_name
	tmp_file=$target_file.tmp

	# Try to get password first (Login items)
	secret_value=$(bw get password "$item_id" 2>/dev/null) || {
		# If that fails, try to get notes (Secure Note items)
		secret_value=$(bw get notes "$item_id" 2>/dev/null) || {
			printf 'Failed to sync %s: item not found or no password/notes field\n' "$secret_name" >&2
			return 1
		}
	}
	
	if [ -z "$secret_value" ]; then
		printf 'Failed to sync %s: empty value\n' "$secret_name" >&2
		return 1
	fi
	
	printf '%s\n' "$secret_value" > "$tmp_file"
	chmod 600 "$tmp_file"
	mv "$tmp_file" "$target_file"
	printf 'Synced %s\n' "$secret_name"
}

load_session
require_bw_session

if [ ! -f "$manifest_file" ]; then
	printf 'secret mirror manifest is missing: %s\n' "$manifest_file" >&2
	exit 1
fi

ensure_dir "$secrets_dir"

while IFS=' ' read -r secret_name item_id extra; do
	[ -n "${secret_name:-}" ] || continue
	case "$secret_name" in
		\#*) continue ;;
	esac
	[ -n "${item_id:-}" ] || continue
	sync_one "$secret_name" "$item_id"
done < "$manifest_file"
