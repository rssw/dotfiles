#!/bin/sh

set -eu

secrets_dir=${SECRET_STORE_DIR:-${HOME:?HOME must be set}/.local/share/secrets}

if [ "$#" -ne 1 ]; then
	printf 'usage: secret-read <name>\n' >&2
	exit 1
fi

secret_file=$secrets_dir/$1

if [ ! -f "$secret_file" ]; then
	printf 'secret is missing: %s\n' "$secret_file" >&2
	printf 'Run `secret-sync` to refresh locally mirrored secrets\n' >&2
	exit 1
fi

exec cat "$secret_file"
