#!/bin/sh
set -eu

ENV_FILE="${MAIL_RSSW_ENV:-$HOME/.local/share/mailutils/rssw.env}"

if [ -f "$ENV_FILE" ]; then
	# shellcheck disable=SC1090
	. "$ENV_FILE"
fi

: "${MAIL_RSSW_USER:?Set MAIL_RSSW_USER in $ENV_FILE}"
: "${MAIL_RSSW_PASS:?Set MAIL_RSSW_PASS in $ENV_FILE}"

MAIL_RSSW_FROM="${MAIL_RSSW_FROM:-$MAIL_RSSW_USER}"
MAIL_RSSW_SMTP_USER="${MAIL_RSSW_SMTP_USER:-$MAIL_RSSW_USER}"
MAIL_RSSW_SMTP_PASS="${MAIL_RSSW_SMTP_PASS:-$MAIL_RSSW_PASS}"
MAIL_RSSW_IMAP_USER="${MAIL_RSSW_IMAP_USER:-$MAIL_RSSW_USER}"
MAIL_RSSW_IMAP_PASS="${MAIL_RSSW_IMAP_PASS:-$MAIL_RSSW_PASS}"
MAIL_RSSW_SMTP_HOST="${MAIL_RSSW_SMTP_HOST:-smtp.rssw.co.za}"
MAIL_RSSW_SMTP_PORT="${MAIL_RSSW_SMTP_PORT:-465}"
MAIL_RSSW_IMAP_HOST="${MAIL_RSSW_IMAP_HOST:-imap.rssw.co.za}"
MAIL_RSSW_IMAP_PORT="${MAIL_RSSW_IMAP_PORT:-993}"

SMTP_URL="smtps://${MAIL_RSSW_SMTP_USER}:${MAIL_RSSW_SMTP_PASS}@${MAIL_RSSW_SMTP_HOST}:${MAIL_RSSW_SMTP_PORT};from=${MAIL_RSSW_FROM};read-recipients"
IMAP_URL="imaps://${MAIL_RSSW_IMAP_USER}:${MAIL_RSSW_IMAP_PASS}@${MAIL_RSSW_IMAP_HOST}:${MAIL_RSSW_IMAP_PORT}"

exec mail \
	--set=mailer.url="$SMTP_URL" \
	--set=mailbox.folder="$IMAP_URL" \
	"$@"
