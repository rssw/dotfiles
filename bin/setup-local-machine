#!/bin/sh

set -eu

HOME_DIR=${HOME:?HOME must be set}

ensure_dir() {
  [ -d "$1" ] || mkdir -p "$1"
}

prompt_default() {
  prompt_text=$1
  default_value=$2
  printf '%s [%s]: ' "$prompt_text" "$default_value" >&2
  read -r response || true
  if [ -n "$response" ]; then
    printf '%s\n' "$response"
  else
    printf '%s\n' "$default_value"
  fi
}

prompt_required() {
  prompt_text=$1
  while :; do
    printf '%s: ' "$prompt_text" >&2
    read -r response || true
    if [ -n "$response" ]; then
      printf '%s\n' "$response"
      return 0
    fi
  done
}

prompt_yes_no() {
  prompt_text=$1
  default_value=$2
  while :; do
    printf '%s [%s]: ' "$prompt_text" "$default_value" >&2
    read -r response || true
    if [ -z "$response" ]; then
      response=$default_value
    fi
    case "$response" in
      y|Y|yes|YES) printf 'yes\n'; return 0 ;;
      n|N|no|NO) printf 'no\n'; return 0 ;;
    esac
  done
}

write_git_config() {
  ensure_dir "$HOME_DIR/.local/share/git"
  
  # Read existing config if present
  git_config_file="$HOME_DIR/.local/share/git/config"
  existing_name=""
  existing_email=""
  existing_github=""
  
  if [ -f "$git_config_file" ]; then
    existing_name=$(git config -f "$git_config_file" user.name 2>/dev/null || true)
    existing_email=$(git config -f "$git_config_file" user.email 2>/dev/null || true)
    existing_github=$(git config -f "$git_config_file" credential.https://github.com.username 2>/dev/null || true)
  fi
  
  if [ -n "$existing_name" ]; then
    git_name=$(prompt_default "Git user.name" "$existing_name")
  else
    git_name=$(prompt_required "Git user.name")
  fi
  
  if [ -n "$existing_email" ]; then
    git_email=$(prompt_default "Git user.email" "$existing_email")
  else
    git_email=$(prompt_required "Git user.email")
  fi
  
  github_user=$(prompt_default "GitHub credential username (optional)" "${existing_github:-}")

  {
    printf '[user]\n'
    printf '\tname = %s\n' "$git_name"
    printf '\temail = %s\n' "$git_email"
    if [ -n "$github_user" ]; then
      printf '\n[credential "https://github.com"]\n'
      printf '\tusername = %s\n' "$github_user"
    fi
  } > "$git_config_file"

  printf 'Wrote %s\n' "$git_config_file"
  
  # Export for use in later prompts
  SETUP_GIT_EMAIL="$git_email"
  SETUP_GIT_NAME="$git_name"
}

write_msmtp_config() {
  ensure_dir "$HOME_DIR/.config/msmtp"
  ensure_dir "$HOME_DIR/.local/share/mailutils"
  
  # Read existing config if present
  msmtp_config="$HOME_DIR/.config/msmtp/config"
  existing_host=""
  existing_port=""
  existing_from=""
  existing_user=""
  existing_password_cmd=""
  
  if [ -f "$msmtp_config" ]; then
    existing_host=$(grep '^[[:space:]]*host' "$msmtp_config" | head -1 | awk '{print $2}' || true)
    existing_port=$(grep '^[[:space:]]*port' "$msmtp_config" | head -1 | awk '{print $2}' || true)
    existing_from=$(grep '^[[:space:]]*from' "$msmtp_config" | head -1 | awk '{print $2}' || true)
    existing_user=$(grep '^[[:space:]]*user' "$msmtp_config" | head -1 | awk '{print $2}' || true)
    existing_password_cmd=$(grep '^[[:space:]]*passwordeval' "$msmtp_config" | head -1 | sed 's/^[[:space:]]*passwordeval[[:space:]]*//' || true)
  fi
  
  if [ -n "$existing_host" ]; then
    smtp_host=$(prompt_default "SMTP host" "$existing_host")
  else
    smtp_host=$(prompt_required "SMTP host")
  fi
  
  smtp_port=$(prompt_default "SMTP port" "${existing_port:-587}")
  smtp_from=$(prompt_default "SMTP from address" "${existing_from:-${SETUP_GIT_EMAIL:-}}")
  smtp_user=$(prompt_default "SMTP username" "${existing_user:-$smtp_from}")
  smtp_secret_cmd=$(prompt_default "SMTP passwordeval / secret lookup command" "${existing_password_cmd:-~/bin/shared/secret-read mail-password}")

  {
    printf 'defaults\n'
    printf '\tauth on\n'
    printf '\ttls on\n'
    printf '\ttls_trust_file /etc/ssl/certs/ca-certificates.crt\n'
    printf '\tlogfile ~/.local/share/mailutils/msmtp.log\n\n'
    printf 'account primary\n'
    printf '\thost %s\n' "$smtp_host"
    printf '\tport %s\n' "$smtp_port"
    printf '\tfrom %s\n' "$smtp_from"
    printf '\tuser %s\n' "$smtp_user"
    printf '\tauth plain\n'
    printf '\tpasswordeval %s\n\n' "$smtp_secret_cmd"
    printf 'account default : primary\n'
  } > "$HOME_DIR/.config/msmtp/config"

  printf 'Wrote %s\n' "$HOME_DIR/.config/msmtp/config"
}

write_mutt_config() {
  ensure_dir "$HOME_DIR/.local/share/mutt"
  
  # Read existing config if present
  mutt_config="$HOME_DIR/.local/share/mutt/private.rc"
  existing_realname=""
  existing_from=""
  
  if [ -f "$mutt_config" ]; then
    existing_realname=$(grep '^set realname' "$mutt_config" | sed 's/^set realname = "\(.*\)"/\1/' || true)
    existing_from=$(grep '^set from' "$mutt_config" | sed 's/^set from = "\(.*\)"/\1/' || true)
  fi
  
  realname=$(prompt_default "Mutt/neomutt real name" "${existing_realname:-${SETUP_GIT_NAME:-}}")
  from_addr=$(prompt_default "Mutt/neomutt from address" "${existing_from:-${SETUP_GIT_EMAIL:-}}")

  {
    printf 'set sendmail = "/usr/bin/msmtp"\n'
    printf 'set use_from = yes\n'
    printf 'set realname = "%s"\n' "$realname"
    printf 'set from = "%s"\n' "$from_addr"
  } > "$HOME_DIR/.local/share/mutt/private.rc"

  printf 'Wrote %s\n' "$HOME_DIR/.local/share/mutt/private.rc"
}

write_notmuch_config() {
  notmuch_config="$HOME_DIR/.notmuch-config"
  
  # Read existing config if present
  existing_name=""
  existing_email=""
  existing_other=""
  
  if [ -f "$notmuch_config" ]; then
    existing_name=$(grep '^name=' "$notmuch_config" | sed 's/^name=//' || true)
    existing_email=$(grep '^primary_email=' "$notmuch_config" | sed 's/^primary_email=//' || true)
    existing_other=$(grep '^other_email=' "$notmuch_config" | sed 's/^other_email=//' || true)
  fi

  notmuch_name=$(prompt_default "Notmuch user name" "${existing_name:-${SETUP_GIT_NAME:-}}")
  notmuch_email=$(prompt_default "Notmuch primary email" "${existing_email:-${SETUP_GIT_EMAIL:-}}")
  notmuch_other=$(prompt_default "Notmuch other emails (comma-separated, optional)" "${existing_other:-}")

  {
    printf '[database]\n'
    printf 'path=%s/.local/share/mail\n\n' "$HOME_DIR"
    printf '[user]\n'
    printf 'name=%s\n' "$notmuch_name"
    printf 'primary_email=%s\n' "$notmuch_email"
    if [ -n "$notmuch_other" ]; then
      printf 'other_email=%s\n' "$notmuch_other"
    fi
    printf '\n[new]\n'
    printf 'tags=new\n'
    printf 'ignore=.mbsync-state\n\n'
    printf '[search]\n'
    printf 'exclude_tags=deleted;spam\n\n'
    printf '[maildir]\n'
    printf 'synchronize_flags=true\n'
  } > "$HOME_DIR/.notmuch-config"

  printf 'Wrote %s\n' "$HOME_DIR/.notmuch-config"
}

write_mbsync_config() {
  mbsync_config="$HOME_DIR/.mbsyncrc"
  
  # Read existing config if present
  existing_host=""
  existing_user=""
  existing_pass_cmd=""
  
  if [ -f "$mbsync_config" ]; then
    existing_host=$(grep '^Host' "$mbsync_config" | head -1 | awk '{print $2}' || true)
    existing_user=$(grep '^User' "$mbsync_config" | head -1 | awk '{print $2}' || true)
    existing_pass_cmd=$(grep '^PassCmd' "$mbsync_config" | head -1 | sed 's/^PassCmd "\(.*\)"/\1/' || true)
  fi

  if [ -n "$existing_host" ]; then
    imap_host=$(prompt_default "IMAP host" "$existing_host")
  else
    imap_host=$(prompt_required "IMAP host")
  fi
  
  if [ -n "$existing_user" ]; then
    imap_user=$(prompt_default "IMAP username" "$existing_user")
  else
    imap_user=$(prompt_required "IMAP username")
  fi
  
  imap_secret_cmd=$(prompt_default "IMAP passwordeval command" "${existing_pass_cmd:-secret-read imap-password}")

  {
    printf '# mbsync configuration\n'
    printf '# Standard folder mapping to ~/.local/share/mail/\n\n'
    printf 'IMAPAccount primary\n'
    printf 'Host %s\n' "$imap_host"
    printf 'User %s\n' "$imap_user"
    printf 'PassCmd "%s"\n' "$imap_secret_cmd"
    printf 'SSLType IMAPS\n'
    printf 'CertificateFile /etc/ssl/certs/ca-certificates.crt\n\n'
    printf 'IMAPStore primary-remote\n'
    printf 'Account primary\n\n'
    printf 'MaildirStore primary-local\n'
    printf 'Path ~/.local/share/mail/\n'
    printf 'Inbox ~/.local/share/mail/INBOX\n'
    printf 'SubFolders Verbatim\n\n'
    printf 'Channel primary-inbox\n'
    printf 'Master :primary-remote:INBOX\n'
    printf 'Slave :primary-local:INBOX\n'
    printf 'Create Both\n'
    printf 'Expunge Both\n'
    printf 'SyncState *\n\n'
    printf 'Channel primary-sent\n'
    printf 'Master :primary-remote:"Sent"\n'
    printf 'Slave :primary-local:Sent\n'
    printf 'Create Both\n'
    printf 'Expunge Both\n'
    printf 'SyncState *\n\n'
    printf 'Channel primary-drafts\n'
    printf 'Master :primary-remote:"Drafts"\n'
    printf 'Slave :primary-local:Drafts\n'
    printf 'Create Both\n'
    printf 'Expunge Both\n'
    printf 'SyncState *\n\n'
    printf 'Channel primary-archive\n'
    printf 'Master :primary-remote:"Archive"\n'
    printf 'Slave :primary-local:Archive\n'
    printf 'Create Both\n'
    printf 'Expunge Both\n'
    printf 'SyncState *\n\n'
    printf 'Channel primary-trash\n'
    printf 'Master :primary-remote:"Trash"\n'
    printf 'Slave :primary-local:Trash\n'
    printf 'Create Both\n'
    printf 'Expunge Both\n'
    printf 'SyncState *\n\n'
    printf 'Group primary\n'
    printf 'Channel primary-inbox\n'
    printf 'Channel primary-sent\n'
    printf 'Channel primary-drafts\n'
    printf 'Channel primary-archive\n'
    printf 'Channel primary-trash\n'
  } > "$HOME_DIR/.mbsyncrc"

  chmod 600 "$HOME_DIR/.mbsyncrc"
  printf 'Wrote %s\n' "$HOME_DIR/.mbsyncrc"
}

printf 'Local machine setup\n\n'
printf 'This helper writes machine-local config only.\n'
printf 'It does not store secrets in the repo.\n\n'

write_git_config
printf '\n'
write_msmtp_config

if [ "$(prompt_yes_no "Configure mutt/neomutt local identity too" "yes")" = yes ]; then
  printf '\n'
  write_mutt_config
fi

if [ "$(prompt_yes_no "Configure mbsync for IMAP mail sync" "yes")" = yes ]; then
  printf '\n'
  write_mbsync_config
  
  # Also offer notmuch config if mbsync is configured
  if [ "$(prompt_yes_no "Configure notmuch for mail indexing" "yes")" = yes ]; then
    printf '\n'
    write_notmuch_config
  fi
fi

printf '\nNext steps\n'
printf -- '- run: gh auth login\n'
printf -- '- run: ~/bin/post-install-checklist\n'
printf -- '- send a test email through msmtp before relying on scripts\n'
